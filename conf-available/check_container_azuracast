CHECK PROGRAM azuracast WITH PATH /etc/monit/scripts/check_container_azuracast.sh
  START PROGRAM = "/etc/monit/scripts/start_azuracast.sh"
  STOP PROGRAM = "/etc/monit/scripts/stop_azuracast.sh"
  IF status != 0 FOR 1 CYCLES THEN RESTART
  IF status != 0 FOR 2 CYCLES THEN alert
